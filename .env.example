# Nike Run Club
# Get your access_token from nike.com browser DevTools:
#
#   METHOD 1 (recommended — "New Way"):
#   1. Go to https://www.nike.com and log in
#   2. Open DevTools (F12) > Application tab > Local Storage
#   3. Click on "https://www.nike.com"
#   4. Find the key that contains "access_token"
#   5. Copy the access_token value (long string starting with eyJ...)
#   6. DO NOT log out after copying (it invalidates the token)
#
#   METHOD 2 (if Method 1 doesn't work):
#   1. Go to https://www.nike.com and open DevTools (F12) > Network tab
#   2. Log in to your Nike account
#   3. Filter network requests by "login" or "token"
#   4. Look for the response containing refresh_token
#   5. Copy the refresh_token value
#
NRC_BEARER_TOKEN=your_nike_access_token_here

# Strava API
# 1. Create an app at https://www.strava.com/settings/api
# 2. Note your Client ID and Client Secret
# 3. Authorize: https://www.strava.com/oauth/authorize?client_id=YOUR_ID&response_type=code&redirect_uri=http://localhost&approval_prompt=force&scope=activity:write
# 4. Copy the 'code' param from the redirect URL
# 5. Exchange for refresh token:
#    curl -X POST https://www.strava.com/api/v3/oauth/token \
#      -d client_id=YOUR_ID -d client_secret=YOUR_SECRET \
#      -d code=YOUR_CODE -d grant_type=authorization_code
# 6. Copy refresh_token from the response
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REFRESH_TOKEN=your_strava_refresh_token

